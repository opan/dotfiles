{
    "chat.instructionsFilesLocations": {
        "/Users/opan.mustopah/Library/Application Support/Code/User/profiles": true
    },
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4o-mini",

    // ---- Vim core options (your `set` lines) ----
    "vim.hlsearch": true,
    "vim.incsearch": true,
    "vim.smartcase": true,
    "vim.useSystemClipboard": true,

    // ---- Plugins VSCodeVim emulates natively ----
    "vim.surround": true,
    "vim.easymotion": true,
    "vim.leader": "\\",              // your leader (default backslash)


    // ---- Normal-mode remaps: splits, tabs, leader keys ----
    "vim.normalModeKeyBindingsNonRecursive": [
        // <c-h/j/k/l> — move between editor splits
      { "before": ["<C-h>"], "commands": ["workbench.action.navigateLeft"] },
      { "before": ["<C-l>"], "commands": ["workbench.action.navigateRight"] },
      { "before": ["<C-k>"], "commands": ["workbench.action.navigateUp"] },
      { "before": ["<C-j>"], "commands": ["workbench.action.navigateDown"] },

        // tab navigation (your <s-left>/<s-right>)
        { "before": ["<S-left>"],  "commands": ["workbench.action.previousEditor"] },
        { "before": ["<S-right>"], "commands": ["workbench.action.nextEditor"] },

        // leader mappings
        { "before": ["<leader>", "d"], "commands": ["workbench.action.toggleSidebarVisibility"] },
        { "before": ["<leader>", "t"], "commands": ["workbench.action.files.newUntitledFile"] },
        { "before": ["<leader>", "c"], "commands": ["workbench.action.closeActiveEditor"] },

        // ; for buffer list, <c-p> for files
        { "before": [";"],     "commands": ["workbench.action.showAllEditors"] },
        { "before": ["<C-p>"], "commands": ["workbench.action.quickOpen"] }
    ],

    // ---- VSCode-native editor options (your `set` lines) ----
    "editor.lineNumbers": "on",
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.detectIndentation": false,
    "editor.renderLineHighlight": "line",
    "editor.foldingStrategy": "indentation",

    // ---- Go: tabs, width 8 (your autocmd Filetype go) ----
    "[go]": {
        "editor.insertSpaces": false,
        "editor.tabSize": 4
    },
    "editor.fontSize": 11
}
